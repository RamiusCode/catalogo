---
interface Props { waNumero?: string }
const { waNumero = 'TU-NUMERO' } = Astro.props;
const waMsg = encodeURIComponent('Hola! 👋 Quiero más información sobre sus invitaciones para reservar.');

const navLinks = [
  { label: 'Inicio',        href: '#inicio' },
  { label: 'Catálogo',      href: '#catalogo' },
  { label: 'Quiénes Somos', href: '#quienes' },
];
---

<header id="navbar" class="fixed top-0 inset-x-0 z-50 transition-all duration-500"
        style="background:#1F2A48; border-bottom:1px solid rgba(255,255,255,0.08)">
  <div class="max-w-[1200px] mx-auto px-5 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a href="#inicio" class="relative z-50 flex items-baseline gap-1 select-none">
      <span style="font-family:'Raleway',sans-serif; font-size:11px; font-weight:400;
                   letter-spacing:0.22em; color:rgba(221,226,236,0.7); text-transform:uppercase">shop</span>
      <span style="font-family:'Raleway',sans-serif; font-size:17px; font-weight:800;
                   letter-spacing:0.01em; color:#ffffff">invitaciones</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-8">
      {navLinks.map(l => (
        <a href={l.href}
           class="relative text-[13px] font-medium transition-colors duration-200 group"
           style="color:rgba(255,255,255,0.75)">
          <span class="group-hover:text-white transition-colors duration-200">{l.label}</span>
          <span class="absolute -bottom-0.5 left-0 w-0 h-[1.5px] rounded-full bg-white/60 group-hover:w-full transition-all duration-300"></span>
        </a>
      ))}
    </nav>

    <!-- Desktop CTA -->
    <a href={`https://wa.me/${waNumero}?text=${waMsg}`} target="_blank" rel="noopener"
       class="hidden lg:inline-flex items-center gap-2 text-white text-[13px] font-semibold px-5 py-2 rounded-full transition-all duration-300 hover:scale-105"
       style="background:rgba(255,255,255,0.18); border:1px solid rgba(255,255,255,0.3); backdrop-filter:blur(8px)">
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.5 14.4c-.3-.2-1.8-.9-2.1-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-1 1.2-.2.2-.4.2-.7.1-.3-.2-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6.1-.1.3-.4.4-.5.1-.2.2-.3.3-.5 0-.2 0-.4-.1-.5 0-.2-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.2.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.8-.7 2-1.4.3-.7.3-1.3.2-1.4-.1-.2-.3-.3-.6-.4M12 2C6.5 2 2 6.5 2 12c0 1.7.5 3.4 1.3 4.8L2 22l5.3-1.4c1.4.8 3 1.2 4.7 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2"/>
      </svg>
      Contactar
    </a>

    <!-- Botón hamburguesa -->
    <button id="burger" aria-label="Abrir menú"
            class="lg:hidden relative z-50 flex items-center gap-2 px-3 py-2 rounded-full transition-all duration-200 active:scale-95"
            style="background:rgba(255,255,255,0.18); border:1px solid rgba(255,255,255,0.28)">
      <span id="burger-label"
            class="font-sans text-[10.5px] font-medium tracking-wide leading-none select-none text-white">Menú</span>
      <div id="burger-icon" class="flex flex-col gap-[4px] w-[13px]">
        <span class="bline block h-[1.5px] w-full rounded-full bg-white transition-all duration-300 origin-center"></span>
        <span class="bline block h-[1.5px] rounded-full bg-white/60 transition-all duration-300" style="width:9px"></span>
        <span class="bline block h-[1.5px] w-full rounded-full bg-white transition-all duration-300 origin-center"></span>
      </div>
    </button>

  </div>
</header>

<!-- ── Overlay para cerrar al tocar fuera ── -->
<div id="mob-overlay" class="fixed inset-0 z-40 pointer-events-none"
     style="opacity:0; background:rgba(18,24,41,0.38); backdrop-filter:blur(4px); -webkit-backdrop-filter:blur(4px)"></div>

<!-- ── Tarjeta flotante compacta ── -->
<div id="mob-menu"
     class="fixed z-50 pointer-events-none"
     style="top:64px; right:18px; width:210px; opacity:0; transform:scale(0.1) translateY(-10px) rotate(-5deg); transform-origin:top right">

  <!-- Card -->
  <div class="rounded-2xl overflow-hidden"
       style="background:#ffffff; border:1px solid #E4E7EF; box-shadow:0 8px 36px rgba(31,42,72,0.13), 0 2px 8px rgba(27,35,51,0.06)">

    <!-- Cabecera -->
    <div class="px-4 pt-3.5 pb-3 flex items-center gap-1.5" style="border-bottom:1px solid #EEF0F5">
      <div class="w-1.5 h-1.5 rounded-full" style="background:#3C4E74"></div>
      <span style="font-family:'Raleway',sans-serif; font-size:11px; font-weight:600; letter-spacing:0.12em; color:#1F2A48; text-transform:uppercase">
        Navegación
      </span>
    </div>

    <!-- Links de navegación -->
    <nav class="flex flex-col px-2 pt-1.5 pb-1">
      {navLinks.map(l => (
        <a href={l.href}
           class="mob-link group relative flex items-center justify-between px-3 py-2.5 rounded-xl overflow-hidden transition-all duration-200"
           style="opacity:0; transform:translateX(14px)">

          <!-- hover bg -->
          <div class="absolute inset-0 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-200"
               style="background:linear-gradient(90deg,#EEF0F5,#E8ECF3)"></div>

          <span class="relative font-medium leading-none transition-colors duration-200 group-hover:text-[#1F2A48]"
                style="font-family:'Raleway',sans-serif; font-size:14.5px; font-weight:500; letter-spacing:0.02em; color:#1B2333">
            {l.label}
          </span>

          <div class="relative flex items-center gap-1 opacity-0 -translate-x-1
                      group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-200">
            <div class="w-1 h-1 rounded-full" style="background:#3C4E74"></div>
            <svg class="w-2.5 h-2.5" style="color:#3C4E74"
                 fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </div>

        </a>
      ))}
    </nav>

    <!-- Separador -->
    <div class="mx-4 my-1" style="height:1px; background:#EEF0F5"></div>

    <!-- WhatsApp compacto -->
    <div id="mob-wa-wrap" class="px-3 py-3" style="opacity:0; transform:translateY(4px)">
      <a href={`https://wa.me/${waNumero}?text=${waMsg}`} target="_blank" rel="noopener"
         class="flex items-center justify-center gap-2 w-full py-2.5 rounded-xl text-white transition-all duration-200 hover:opacity-90"
         style="background:#25D366; box-shadow:0 2px 10px rgba(37,211,102,0.22)">
        <svg style="width:14px;height:14px;flex-shrink:0" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.5 14.4c-.3-.2-1.8-.9-2.1-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-1 1.2-.2.2-.4.2-.7.1-.3-.2-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6.1-.1.3-.4.4-.5.1-.2.2-.3.3-.5 0-.2 0-.4-.1-.5 0-.2-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.2.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.8-.7 2-1.4.3-.7.3-1.3.2-1.4-.1-.2-.3-.3-.6-.4M12 2C6.5 2 2 6.5 2 12c0 1.7.5 3.4 1.3 4.8L2 22l5.3-1.4c1.4.8 3 1.2 4.7 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2"/>
        </svg>
        <span style="font-family:'Raleway',sans-serif; font-size:12.5px; font-weight:600; letter-spacing:0.05em">
          WhatsApp
        </span>
      </a>
    </div>

  </div>
</div>

<script>
  import { gsap } from 'gsap';

  const navbar      = document.getElementById('navbar')!;
  const burger      = document.getElementById('burger')!;
  const overlay     = document.getElementById('mob-overlay')!;
  const menu        = document.getElementById('mob-menu')!;
  const links       = menu.querySelectorAll('.mob-link');
  const waWrap      = document.getElementById('mob-wa-wrap')!;
  const blines      = burger.querySelectorAll('.bline');
  const burgerLabel = document.getElementById('burger-label')!;
  let open = false;

  // Navbar siempre azul marino sólido. Solo agrega una sombra sutil al bajar (el color no cambia).
  window.addEventListener('scroll', () => {
    navbar.style.boxShadow = window.scrollY > 30 ? '0 4px 20px rgba(31,42,72,0.18)' : '';
  }, { passive: true });

  burger.addEventListener('click', () => open ? closeMenu() : openMenu());
  overlay.addEventListener('click', closeMenu);

  function openMenu() {
    open = true;
    menu.style.pointerEvents  = 'auto';
    overlay.style.pointerEvents = 'auto';

    // Icono → X
    burgerLabel.textContent = 'Cerrar';
    gsap.to(blines[0], { rotate: 45,  y: 5.5,  duration: 0.3, ease: 'power2.inOut' });
    gsap.to(blines[1], { opacity: 0,  x: 6,    duration: 0.18 });
    gsap.to(blines[2], { rotate: -45, y: -5.5, duration: 0.3, ease: 'power2.inOut' });

    // Overlay con desenfoque — fundido suave
    gsap.to(overlay, { opacity: 1, duration: 0.35, ease: 'power2.out' });

    // Pequeño "pop" del botón al abrir
    gsap.fromTo(burger, { scale: 0.9 }, { scale: 1, duration: 0.4, ease: 'back.out(3)' });

    // La tarjeta BROTA desde la esquina del botón — escala desde un punto + giro + rebote
    gsap.fromTo(menu,
      { opacity: 0, scale: 0.1, y: -10, rotate: -5 },
      { opacity: 1, scale: 1, y: 0, rotate: 0, duration: 0.6, ease: 'back.out(1.8)' });

    // Links entran deslizándose desde la derecha, uno por uno
    gsap.to([...links], {
      opacity: 1, x: 0,
      duration: 0.4, stagger: 0.08,
      ease: 'power3.out', delay: 0.22,
    });
    gsap.to(waWrap, { opacity: 1, y: 0, duration: 0.4, ease: 'back.out(1.7)', delay: 0.42 });
  }

  function closeMenu() {
    open = false;
    menu.style.pointerEvents  = 'none';
    overlay.style.pointerEvents = 'none';

    burgerLabel.textContent = 'Menú';
    gsap.to(blines[0], { rotate: 0, y: 0, duration: 0.28, ease: 'power2.inOut' });
    gsap.to(blines[1], { opacity: 1, x: 0, duration: 0.18, delay: 0.08 });
    gsap.to(blines[2], { rotate: 0, y: 0, duration: 0.28, ease: 'power2.inOut' });

    gsap.to(overlay, { opacity: 0, duration: 0.25 });

    // La tarjeta se repliega de vuelta hacia el botón
    gsap.to(menu, {
      opacity: 0,
      scale: 0.1,
      y: -10,
      rotate: -5,
      duration: 0.32,
      ease: 'power2.in',
      onComplete() {
        gsap.set([...links], { opacity: 0, x: 14 });
        gsap.set(waWrap,     { opacity: 0, y: 4 });
      },
    });
  }

  links.forEach(l => l.addEventListener('click', closeMenu));
</script>
