---
---

<section id="contacto" class="py-24 bg-gradient-to-br from-cream-100 to-gold-50">
  <div class="max-w-3xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center mb-12">
      <p class="cont-tag font-sans text-xs tracking-[0.4em] uppercase text-gold-500 mb-3">Hablemos</p>
      <h2 class="cont-title section-title mb-4">Cotiza tu Invitación</h2>
      <div class="divider-gold max-w-xs mx-auto">
        <span class="font-script text-gold-400 text-xl">&#10022;</span>
      </div>
      <p class="cont-desc font-sans text-sm font-light text-gray-500 max-w-md mx-auto mt-4 leading-relaxed">
        Cuéntanos sobre tu boda y te enviaremos una propuesta personalizada en menos de 24 horas.
      </p>
    </div>

    <!-- Formulario -->
    <form id="contact-form" class="cont-form bg-white/80 backdrop-blur-sm border border-gold-100 p-8 md:p-12 space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex flex-col gap-2">
          <label class="font-sans text-xs tracking-widest uppercase text-gray-500">Nombre *</label>
          <input
            type="text"
            name="nombre"
            required
            placeholder="Tu nombre"
            class="border-b border-gray-200 focus:border-gold-400 outline-none bg-transparent font-sans text-sm text-gray-700 py-2 placeholder:text-gray-300 transition-colors"
          />
        </div>
        <div class="flex flex-col gap-2">
          <label class="font-sans text-xs tracking-widest uppercase text-gray-500">Pareja *</label>
          <input
            type="text"
            name="pareja"
            required
            placeholder="Nombre de tu pareja"
            class="border-b border-gray-200 focus:border-gold-400 outline-none bg-transparent font-sans text-sm text-gray-700 py-2 placeholder:text-gray-300 transition-colors"
          />
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex flex-col gap-2">
          <label class="font-sans text-xs tracking-widest uppercase text-gray-500">Email *</label>
          <input
            type="email"
            name="email"
            required
            placeholder="correo@ejemplo.com"
            class="border-b border-gray-200 focus:border-gold-400 outline-none bg-transparent font-sans text-sm text-gray-700 py-2 placeholder:text-gray-300 transition-colors"
          />
        </div>
        <div class="flex flex-col gap-2">
          <label class="font-sans text-xs tracking-widest uppercase text-gray-500">Fecha de boda</label>
          <input
            type="date"
            name="fecha"
            class="border-b border-gray-200 focus:border-gold-400 outline-none bg-transparent font-sans text-sm text-gray-700 py-2 transition-colors"
          />
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <label class="font-sans text-xs tracking-widest uppercase text-gray-500">Modelo de interés</label>
        <select
          name="modelo"
          class="border-b border-gray-200 focus:border-gold-400 outline-none bg-transparent font-sans text-sm text-gray-700 py-2 transition-colors"
        >
          <option value="">Seleccionar modelo...</option>
          <option>Eternal Rose — Romántica</option>
          <option>Golden Vow — Clásica</option>
          <option>Magnolia — Botánica</option>
          <option>Noir & Or — Moderna</option>
          <option>Blush Peony — Romántica</option>
          <option>Ivory Classic — Clásica</option>
          <option>No sé aún, necesito asesoría</option>
        </select>
      </div>

      <div class="flex flex-col gap-2">
        <label class="font-sans text-xs tracking-widest uppercase text-gray-500">Mensaje</label>
        <textarea
          name="mensaje"
          rows="4"
          placeholder="Cuéntanos más sobre tu boda, cantidad de invitados, colores, etc."
          class="border-b border-gray-200 focus:border-gold-400 outline-none bg-transparent font-sans text-sm text-gray-700 py-2 placeholder:text-gray-300 transition-colors resize-none"
        ></textarea>
      </div>

      <div class="text-center pt-4">
        <button
          type="submit"
          class="btn-gold w-full sm:w-auto px-16"
        >
          Enviar Consulta
        </button>
      </div>
    </form>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.cont-tag, .cont-title, .cont-desc', {
    scrollTrigger: { trigger: '#contacto', start: 'top 80%' },
    opacity: 0, y: 25, duration: 0.8, stagger: 0.15,
  });

  gsap.from('.cont-form', {
    scrollTrigger: { trigger: '.cont-form', start: 'top 85%' },
    opacity: 0, y: 40, duration: 1, ease: 'power3.out',
  });

  // Efecto submit (placeholder — conectar con backend)
  document.getElementById('contact-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = e.currentTarget.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.textContent = 'Enviado ✓';
    btn.disabled = true;
    gsap.to(btn, { scale: 1.05, duration: 0.2, yoyo: true, repeat: 1 });
  });
</script>
