---
---

<section id="quienes" class="py-20 px-5 bg-bg-card border-y border-line">
  <div class="max-w-[620px] mx-auto text-center">

    <!-- Texto -->
    <div class="qs-left">
      <div class="inline-flex items-center gap-2 bg-brand-50 text-brand-600 text-[11px] font-semibold tracking-[0.15em] uppercase px-3.5 py-1.5 rounded-full mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-brand inline-block"></span>
        Quiénes Somos
      </div>

      <h2 class="font-display text-4xl md:text-[2.8rem] font-light text-ink leading-[1.1] tracking-tight mb-5">
        El primer <span class="italic" style="color:#C4963E">detalle</span><br>que ven tus invitados
      </h2>

      <p class="text-[15px] text-ink-soft leading-relaxed mb-8 max-w-[460px] mx-auto">
        Creamos invitaciones <strong class="font-semibold text-ink">digitales</strong> y <strong class="font-semibold text-ink">100% personalizadas</strong> para tu boda. Elige tu modelo y lo adaptamos a tu estilo.
      </p>

      <ul class="inline-flex flex-col gap-4 text-left mx-auto">
        {[
          'Personalizada con tu nombre, fecha y lugar',
          'Lista para compartir por WhatsApp y redes sociales',
          'Diseños elegantes para bodas y todo evento',
        ].map(txt => (
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-brand shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-[14px] text-ink-soft">{txt}</span>
          </li>
        ))}
      </ul>
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.qs-left > *', {
    scrollTrigger: { trigger: '#quienes', start: 'top 78%' },
    opacity: 0, y: 24, duration: 0.65, stagger: 0.1, ease: 'power3.out',
  });
</script>
