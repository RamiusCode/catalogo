---
const pasos = [
  {
    num:         '01',
    titulo:      'Elige tu modelo',
    descripcion: 'Explora el catálogo y mira el demo en vivo de cada invitación. Quédate con el que más te guste.',
    p:           ['M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.562.562 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z'],
  },
  {
    num:         '02',
    titulo:      'Envíanos tus datos',
    descripcion: 'Por WhatsApp nos pasas los nombres, fecha, lugar y fotos. Nosotros armamos tu invitación.',
    p:           ['M2.25 12.76c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.076-4.076a1.526 1.526 0 011.037-.443 48.282 48.282 0 005.68-.494c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z'],
  },
  {
    num:         '03',
    titulo:      'Recibe tu invitación',
    descripcion: 'Te entregamos tu link listo para compartir con todos tus invitados, en cualquier celular.',
    p:           ['M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z'],
  },
];
---

<section id="proceso" class="py-20 px-5" style="background:#ffffff">
  <div class="max-w-[1100px] mx-auto">

    <!-- Header -->
    <div class="text-center mb-14">
      <p style="font-family:'Raleway',sans-serif; font-size:10.5px; font-weight:700;
                letter-spacing:0.22em; text-transform:uppercase; color:#C4963E; margin-bottom:10px">
        Cómo funciona
      </p>
      <h2 style="font-family:'Raleway',sans-serif; font-size:clamp(1.6rem,4vw,2.3rem);
                 line-height:1.15; letter-spacing:-0.01em">
        <span style="font-weight:300; color:#5A6377">Así de </span><span style="font-family:'Playfair Display',serif; font-style:italic; font-weight:600; color:#1F2A48">fácil</span>
      </h2>
      <div class="flex items-center justify-center gap-2.5 mt-3">
        <span style="display:block; width:34px; height:1px; background:linear-gradient(90deg,transparent,#C4963E)"></span>
        <span style="color:#C4963E; font-size:11px; line-height:1">&#10022;</span>
        <span style="display:block; width:34px; height:1px; background:linear-gradient(90deg,#C4963E,transparent)"></span>
      </div>
    </div>

    <!-- Pasos -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-6 relative">

      <!-- Línea conectora (solo desktop) -->
      <div class="hidden md:block absolute left-[16.66%] right-[16.66%]"
           style="top:36px; height:1px; background:linear-gradient(90deg,transparent,#E4D2A8,transparent)"></div>

      {pasos.map((paso, i) => (
        <div class="proc-step text-center relative" data-i={i} style="opacity:0; transform:translateY(30px)">

          <!-- Círculo con icono -->
          <div class="relative inline-flex items-center justify-center mx-auto mb-5"
               style="width:72px; height:72px; border-radius:9999px; background:#1F2A48;
                      box-shadow:0 8px 22px rgba(31,42,72,0.22)">
            <svg class="w-8 h-8" style="color:#ffffff" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.6">
              {paso.p.map(d => <path stroke-linecap="round" stroke-linejoin="round" d={d}/>)}
            </svg>
            <!-- Número dorado -->
            <span class="absolute -top-1.5 -right-1.5 flex items-center justify-center"
                  style="width:26px; height:26px; border-radius:9999px; background:#C4963E; color:#ffffff;
                         font-family:'Outfit',sans-serif; font-size:12px; font-weight:800; border:2px solid #ffffff">
              {paso.num}
            </span>
          </div>

          <h3 style="font-family:'Outfit',sans-serif; font-size:16px; font-weight:700; color:#1B2333; margin-bottom:8px">
            {paso.titulo}
          </h3>
          <p class="mx-auto" style="font-family:'Raleway',sans-serif; font-size:13px; font-weight:400;
                                    line-height:1.6; color:#5A6377; max-width:280px">
            {paso.descripcion}
          </p>

        </div>
      ))}
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.to('.proc-step', {
    scrollTrigger: { trigger: '#proceso', start: 'top 78%' },
    opacity: 1, y: 0, duration: 0.7, stagger: 0.15, ease: 'power3.out',
  });
</script>
