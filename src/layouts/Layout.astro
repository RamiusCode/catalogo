---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Catálogo de Bodas — Invitaciones Elegantes',
  description = 'Descubre nuestra colección de invitaciones y papelería para bodas. Diseños únicos, elegantes y personalizados para tu día especial.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fuentes (carga rápida con preconnect) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Raleway:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,600;1,400;1,600&family=Outfit:wght@300;400;500;600;700;800&display=swap" />
  </head>
  <body>
    <slot />
  </body>
</html>
