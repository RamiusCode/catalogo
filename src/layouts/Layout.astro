---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Catálogo de Bodas — Invitaciones Elegantes',
  description = 'Descubre nuestra colección de invitaciones y papelería para bodas. Diseños únicos, elegantes y personalizados para tu día especial.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot />
  </body>
</html>
